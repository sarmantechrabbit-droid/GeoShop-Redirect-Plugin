{
  "name": "geoflow-redirect",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "node ./scripts/guard-dev-env.js && shopify app dev",
    "dev:reset": "node ./scripts/guard-dev-env.js && shopify app dev --reset",
    "dev:clean": "shopify app dev clean",
    "app:dev": "react-router dev --host 0.0.0.0 --port 3000 --strictPort",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "lint": "eslint .",
    "shopify": "shopify"
  },
  "dependencies": {
    "@react-router/dev": "^7.17.0",
    "@react-router/node": "^7.17.0",
    "@react-router/serve": "^7.17.0",
    "@shopify/app-bridge-react": "^4.1.6",
    "@shopify/polaris": "^12.0.0",
    "@shopify/polaris-icons": "^9.3.1",
    "@shopify/shopify-app-react-router": "^0.3.0",
    "@shopify/shopify-app-session-storage-memory": "^4.0.0",
    "isbot": "^5.1.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.17.0",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@shopify/cli": "3.94.3",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0"
  }
}
